#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/theme" || exit

if ! curl -s -X POST https://virtualPet.mimobox.sh/explore > /dev/null; then
  echo " ${PINK}Pixel can't reach the server right now :(${RESET}"
  exit 1
fi

messages=(
  " ${PINK}Pixel brought you something... ᘛ⁐ᕐᐷ${RESET}"
  " ${PINK}Pixel found bugs outside... [CONFLICT (content): 〰 〰 ꕤ ]${RESET}"
  " ${PINK}Pixel made a friend at the park... ૮ฅ•ﻌ•აฅ  ฅ^•ﻌ•^ฅ${RESET}"
)

echo "${messages[$RANDOM % ${#messages[@]}]}"