#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/theme" || exit

result=$(curl -s -o /dev/null -w "%{http_code}" -X POST https://virtualpet.mimobox.sh/train 2>/dev/null)

if [[ "$result" != "200" ]]; then
    result=$(curl -sk -o /dev/null -w "%{http_code}" -X POST https://virtualpet.mimobox.sh/train 2>/dev/null)
fi

if [[ "$result" != "200" ]]; then
    echo " ${PINK}Pixel can't reach the server right now :(${RESET}"
    exit 1
fi

messages=(
  " ${PINK} You've taught Pixel a new trick!${RESET}"
  " ${PINK} ฅ^•ﻌ•^ฅ *backflips*${RESET}"
  " ${PINK} ε=ε=┏( >_<)┛   ε=ε=ᓚ(^. .^)   ... You both start training for a 5k ... ${RESET}"
)

echo "${messages[$RANDOM % ${#messages[@]}]}"