#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/theme" || exit

# try normal SSL first
result=$(curl -s -o /dev/null -w "%{http_code}" -X POST https://virtualpet.mimobox.sh/feed 2>/dev/null)

if [[ "$result" != "200" ]]; then
    # fallback for Windows Git Bash SSL issues
    result=$(curl -sk -o /dev/null -w "%{http_code}" -X POST https://virtualpet.mimobox.sh/feed 2>/dev/null)
fi

if [[ "$result" != "200" ]]; then
    echo " ${PINK}Pixel can't reach the server right now :(${RESET}"
    exit 1
fi

messages=(
  " ${PINK}Pixel's been fed!${RESET}"
  " ${PINK}Nom nom nom...${RESET}"
  " ${PINK}She ate it all!${RESET}"
)

echo "${messages[$RANDOM % ${#messages[@]}]}"