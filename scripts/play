#!/usr/bin/env bash
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$SCRIPT_DIR/theme" || exit

result=$(curl -s -o /dev/null -w "%{http_code}" -X POST https://virtualpet.mimobox.sh/play 2>/dev/null)

if [[ "$result" != "200" ]]; then
    result=$(curl -sk -o /dev/null -w "%{http_code}" -X POST https://virtualpet.mimobox.sh/play 2>/dev/null)
fi

if [[ "$result" != "200" ]]; then
    echo " ${PINK}Pixel can't reach the server right now :(${RESET}"
    exit 1
fi

messages=(
  " ${PINK} You throw a ball of yarn at Pixel${RESET}"
  " ${PINK} Pixel challenged you to thumb war... somehow...${RESET}"
  " ${PINK} ᓚᘏᕐᐷ You throw a toy mouse at Pixel${RESET}"
)

echo "${messages[$RANDOM % ${#messages[@]}]}"